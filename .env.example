# Postgres
DATABASE_URL=postgres://tts:tts@postgres:5432/tts?sslmode=disable

# Valkey
VALKEY_URL=redis://valkey:6379/0

# NATS
NATS_URL=nats://nats:4222

# Inference gRPC (dns:/// + round_robin when INFERENCE_REPLICAS>1 in compose)
INFERENCE_GRPC_ADDR=dns:///inference:50051

# Platform defaults
PLATFORM_DEFAULT_PRICE_PER_MINUTE=0.05
DEFAULT_USERNAME=dev
DEFAULT_PASSWORD=devpassword
DEFAULT_WALLET_USD=20

# Inference (production: always real model)
# Set backend only via compose override (scripts/use-backend.sh). Do not duplicate keys here.
REQUIRE_REAL_INFERENCE=true
INFERENCE_MOCK=false

# Hugging Face (required for gated model canopylabs/orpheus-3b-0.1-ft)
HF_TOKEN=

# vLLM (Lightning / CUDA)
ORPHEUS_MODEL_NAME=canopylabs/orpheus-3b-0.1-ft
ORPHEUS_TOKENIZER=canopylabs/orpheus-3b-0.1-pretrained
VLLM_DEVICE=cuda
# Profile: l4 (24GB tuning) | t4 (16GB caps, float16, max_model_len=8192, gpu_mem=0.75)
INFERENCE_GPU_PROFILE=l4
VLLM_GPU_MEMORY_UTILIZATION=0.85
# T4-equivalent on any GPU (fair benchmark on L4):
# INFERENCE_GPU_PROFILE=t4
# VLLM_GPU_MEMORY_UTILIZATION=0.75
# VLLM_MAX_MODEL_LEN=8192
# VLLM_DTYPE=   # t4 profile forces float16; l4 uses bfloat16 on CC>=8
SNAC_DEVICE=cuda

# llama.cpp (L40S profile) — use: ./scripts/compose-up.sh llamacpp
ORPHEUS_GGUF_MODEL=Orpheus-3b-FT-Q4_K_M.gguf
ORPHEUS_GGUF_HF_REPO=lex-au/Orpheus-3b-FT-Q4_K_M.gguf
LLAMACPP_URL=http://llama-cpp-server:5006/v1/completions
LLAMACPP_REPLICAS=1
LLAMACPP_CTX_SIZE=4096
LLAMACPP_PARALLEL=48
LLAMACPP_FLASH_ATTN=on
LLAMACPP_BATCH_SIZE=512
LLAMACPP_UBATCH_SIZE=256
LLAMACPP_CACHE_TYPE_K=q4_0
LLAMACPP_CACHE_TYPE_V=q4_0
LLAMACPP_PRIO=2
# SNAC gRPC replicas (compose --scale inference=N); API load-balances streams
INFERENCE_REPLICAS=3
ORPHEUS_MAX_TOKENS=8192
ORPHEUS_TEMPERATURE=0.6
ORPHEUS_TOP_P=0.9
ORPHEUS_API_TIMEOUT=120
LLAMA_CPU_THREADS=6

# Rate limits (per user defaults; overrides via admin API)
RATE_LIMIT_RPM=60
RATE_LIMIT_RPH=1000
RATE_LIMIT_RPD=10000
# Admin key for PUT/GET/DELETE /v1/admin/users/{userId}/rate-limit (X-Admin-Key or Bearer)
PLATFORM_ADMIN_KEY=

# Billing
BILLING_COALESCE_MS=300
DELIVERY_BALANCE_REFRESH_STREAM_SEC=5
DELIVERY_BALANCE_REFRESH_WS_SEC=2

# API synthesis cap (≈ INFERENCE_REPLICAS × practical slots per process)
MAX_CONCURRENT_SYNTHESIS=48
GRPC_MAX_WORKERS=48
# Bench: raise to avoid 429 when testing high concurrency
# RATE_LIMIT_RPM=5000
METRICS_WALLET_PER_USER=true
API_PORT=8080
METERING_METRICS_PORT=8081
