{
  "title": "TTS Platform",
  "uid": "tts-platform",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 4,
  "refresh": "10s",
  "tags": ["tts"],
  "templating": { "list": [] },
  "panels": [
    {
      "type": "stat",
      "title": "TTFB p95 (dashboard range)",
      "description": "Uses increase() over the selected time range — works with sparse TTS traffic (unlike rate[5m]).",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(increase(tts_time_to_first_byte_seconds_bucket[$__range])) by (le, transport))",
          "legendFormat": "{{transport}}",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "type": "stat",
      "title": "Request duration p95 (range)",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(increase(tts_request_duration_seconds_bucket[$__range])) by (le, route, transport))",
          "legendFormat": "{{route}}",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "type": "stat",
      "title": "Realtime factor p95 (range)",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(increase(tts_realtime_factor_bucket[$__range])) by (le, transport))",
          "legendFormat": "{{transport}}",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "TTFB p95 (per step)",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(increase(tts_time_to_first_byte_seconds_bucket[$__rate_interval])) by (le, transport))",
          "legendFormat": "p95 {{transport}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "TTFB avg (per step)",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 4 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "sum(increase(tts_time_to_first_byte_seconds_sum[$__rate_interval])) by (transport) / sum(increase(tts_time_to_first_byte_seconds_count[$__rate_interval])) by (transport)",
          "legendFormat": "avg {{transport}}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "TTFB avg (process lifetime)",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 4 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "sum(tts_time_to_first_byte_seconds_sum) by (transport) / sum(tts_time_to_first_byte_seconds_count) by (transport)",
          "legendFormat": "{{transport}}",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Active streams (current)",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus" },
      "targets": [{ "expr": "tts_active_streams", "legendFormat": "active" }]
    },
    {
      "type": "timeseries",
      "title": "Active streams (peak per step)",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "max_over_time(tts_active_streams[$__interval])",
          "legendFormat": "peak"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Audio seconds (per step)",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "sum(increase(tts_audio_seconds_generated_total[$__rate_interval])) by (transport)",
          "legendFormat": "{{transport}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Request duration p95 (per step)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(increase(tts_request_duration_seconds_bucket[$__rate_interval])) by (le, route, transport))",
          "legendFormat": "{{route}} {{transport}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Realtime factor p95 (per step)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(increase(tts_realtime_factor_bucket[$__rate_interval])) by (le, transport))",
          "legendFormat": "p95 {{transport}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Realtime factor avg (per step)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(tts_realtime_factor_sum[$__rate_interval])) by (transport) / sum(increase(tts_realtime_factor_count[$__rate_interval])) by (transport)",
          "legendFormat": "avg {{transport}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Request duration avg (per step)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "sum(increase(tts_request_duration_seconds_sum[$__rate_interval])) by (route, transport) / sum(increase(tts_request_duration_seconds_count[$__rate_interval])) by (route, transport)",
          "legendFormat": "{{route}} {{transport}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Wallet balance (USD)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } },
      "targets": [
        {
          "expr": "wallet_balance_usd",
          "legendFormat": "{{user_id}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP latency p95 (per step)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(increase(http_request_duration_seconds_bucket[$__rate_interval])) by (le, route))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Metering events (per step)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 44 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "increase(metering_events_processed_total[$__rate_interval])",
          "legendFormat": "events"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Metering debit errors (per step)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 44 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "increase(metering_debit_errors_total[$__rate_interval])",
          "legendFormat": "errors"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Wallet cache L2 misses (per step)",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 52 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "increase(cache_l2_miss_total[$__rate_interval])",
          "legendFormat": "misses"
        }
      ]
    }
  ]
}
