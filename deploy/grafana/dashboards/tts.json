{
  "title": "TTS Platform",
  "uid": "tts-platform",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "10s",
  "tags": ["tts"],
  "templating": { "list": [] },
  "panels": [
    {
      "type": "timeseries",
      "title": "TTFB p95",
      "description": "rate() over 5m windows; needs TTS traffic in the selected time range.",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(tts_time_to_first_byte_seconds_bucket[5m])) by (le, transport))",
          "legendFormat": "p95 {{transport}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "TTFB avg",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "sum(rate(tts_time_to_first_byte_seconds_sum[5m])) by (transport) / sum(rate(tts_time_to_first_byte_seconds_count[5m])) by (transport)",
          "legendFormat": "avg {{transport}}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "TTFB avg (all time)",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "sum(tts_time_to_first_byte_seconds_sum) by (transport) / sum(tts_time_to_first_byte_seconds_count) by (transport)",
          "legendFormat": "{{transport}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Active streams (current)",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus" },
      "targets": [{ "expr": "tts_active_streams", "legendFormat": "active" }]
    },
    {
      "type": "timeseries",
      "title": "Active streams (peak per interval)",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "max_over_time(tts_active_streams[$__interval])",
          "legendFormat": "peak"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Audio seconds (rate)",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "sum(rate(tts_audio_seconds_generated_total[5m])) by (transport)",
          "legendFormat": "{{transport}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Request duration p95",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(tts_request_duration_seconds_bucket[5m])) by (le, route, transport))",
          "legendFormat": "{{route}} {{transport}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Realtime factor p95",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(tts_realtime_factor_bucket[5m])) by (le, transport))",
          "legendFormat": "p95 {{transport}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Realtime factor avg",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(tts_realtime_factor_sum[5m])) by (transport) / sum(rate(tts_realtime_factor_count[5m])) by (transport)",
          "legendFormat": "avg {{transport}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Request duration avg",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "sum(rate(tts_request_duration_seconds_sum[5m])) by (route, transport) / sum(rate(tts_request_duration_seconds_count[5m])) by (route, transport)",
          "legendFormat": "{{route}} {{transport}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Wallet balance (USD)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } },
      "targets": [
        {
          "expr": "wallet_balance_usd",
          "legendFormat": "{{user_id}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP latency p95",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, route))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Metering events",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 40 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "rate(metering_events_processed_total[5m])",
          "legendFormat": "events/s"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Metering debit errors",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 40 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "rate(metering_debit_errors_total[5m])",
          "legendFormat": "errors/s"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Wallet cache L2 misses",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 48 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "rate(cache_l2_miss_total[5m])",
          "legendFormat": "misses/s"
        }
      ]
    }
  ]
}
