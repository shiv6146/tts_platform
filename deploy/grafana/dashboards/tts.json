{
  "title": "TTS Platform",
  "uid": "tts-platform",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "type": "timeseries",
      "title": "TTFB (p95)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(tts_time_to_first_byte_seconds_bucket[5m])) by (le, transport))",
          "legendFormat": "{{transport}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Active streams",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [{"expr": "tts_active_streams"}]
    },
    {
      "type": "timeseries",
      "title": "Audio seconds generated",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "sum(rate(tts_audio_seconds_generated_total[5m])) by (transport)",
          "legendFormat": "{{transport}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Metering events",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [{"expr": "rate(metering_events_processed_total[5m])"}]
    },
    {
      "type": "timeseries",
      "title": "HTTP latency p95",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, route))",
          "legendFormat": "{{route}}"
        }
      ]
    }
  ]
}
