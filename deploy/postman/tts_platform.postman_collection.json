{
  "info": {
    "_postman_id": "tts-platform-orpheus",
    "name": "Orpheus TTS Platform",
    "description": "HTTP API for the Orpheus TTS platform.\n\n**Auth flow:** Run **Register** or **Login** first — the test script saves `apiKey` (`sk-...`) to the collection. All other protected requests use collection Bearer auth (`{{apiKey}}`).\n\n**Live TTS:** WebSocket `GET {{baseUrl}}/v1/tts/live` with `Authorization: Bearer {{apiKey}}`.\n\n**Stream TTS:** `POST /v1/tts/stream` returns PCM (`application/octet-stream`).\n\n**Docs:** `{{baseUrl}}/docs`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{apiKey}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "username",
      "value": "postman_user"
    },
    {
      "key": "password",
      "value": "changeme123"
    },
    {
      "key": "apiKey",
      "value": "",
      "description": "Bearer sk-... — set automatically by Register, Login, or Create API key"
    },
    {
      "key": "jobId",
      "value": "",
      "description": "UUID from async TTS create"
    },
    {
      "key": "keyId",
      "value": "",
      "description": "API key UUID for revoke"
    }
  ],
  "item": [
    {
      "name": "Health & ops",
      "item": [
        {
          "name": "Liveness (health)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        },
        {
          "name": "Liveness (livez)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/livez"
          }
        },
        {
          "name": "Prometheus metrics (API)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/metrics"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register user",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Register succeeded', function () {",
                  "  pm.expect(pm.response.code).to.equal(201);",
                  "});",
                  "const body = pm.response.json();",
                  "if (body.apiKey) {",
                  "  pm.collectionVariables.set('apiKey', body.apiKey);",
                  "  pm.test('API key saved to collection', function () {",
                  "    pm.expect(body.apiKey).to.match(/^sk-/);",
                  "  });",
                  "}",
                  "if (body.id) {",
                  "  pm.collectionVariables.set('userId', body.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/v1/auth/register",
            "description": "Creates user, wallet, and initial API key. Response `apiKey` is stored in the collection for Bearer auth."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login succeeded', function () {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "const body = pm.response.json();",
                  "if (body.apiKey) {",
                  "  pm.collectionVariables.set('apiKey', body.apiKey);",
                  "  pm.test('API key saved to collection', function () {",
                  "    pm.expect(body.apiKey).to.match(/^sk-/);",
                  "  });",
                  "}",
                  "if (body.id) {",
                  "  pm.collectionVariables.set('userId', body.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/v1/auth/login",
            "description": "Verifies username/password and mints a new API key. Response `apiKey` is stored in the collection."
          }
        },
        {
          "name": "Create API key",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('API key created', function () {",
                  "  pm.expect(pm.response.code).to.equal(201);",
                  "});",
                  "const body = pm.response.json();",
                  "if (body.secret) {",
                  "  pm.collectionVariables.set('apiKey', body.secret);",
                  "  pm.test('API key saved to collection', function () {",
                  "    pm.expect(body.secret).to.match(/^sk-/);",
                  "  });",
                  "}",
                  "if (body.id) {",
                  "  pm.collectionVariables.set('keyId', body.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/v1/auth/api-keys",
            "description": "Requires Bearer {{apiKey}}. Mints another key; `secret` overwrites collection apiKey."
          }
        },
        {
          "name": "List API keys",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/v1/auth/api-keys"
          }
        },
        {
          "name": "Revoke API key",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/v1/auth/api-keys/{{keyId}}"
          }
        }
      ]
    },
    {
      "name": "Wallet & usage",
      "item": [
        {
          "name": "Get wallet",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/v1/wallet"
          }
        },
        {
          "name": "List usage",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/usage?limit=50&offset=0",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "usage"],
              "query": [
                { "key": "limit", "value": "50" },
                { "key": "offset", "value": "0" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "TTS",
      "item": [
        {
          "name": "Stream TTS (chunked PCM)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Hello from Postman. This is a streaming synthesis test.\",\n  \"voice\": \"tara\"\n}"
            },
            "url": "{{baseUrl}}/v1/tts/stream"
          }
        },
        {
          "name": "Create async TTS job",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 202) {",
                  "  const j = pm.response.json();",
                  "  if (j.jobId) pm.collectionVariables.set('jobId', j.jobId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Hello from async TTS.\",\n  \"voice\": \"tara\"\n}"
            },
            "url": "{{baseUrl}}/v1/tts/async"
          }
        },
        {
          "name": "Get async job status",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/v1/tts/async/{{jobId}}"
          }
        },
        {
          "name": "Download async job audio (WAV)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/v1/tts/async/{{jobId}}/audio"
          }
        },
        {
          "name": "Live TTS (WebSocket)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{apiKey}}",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/v1/tts/live",
            "description": "Use WebSocket protocol. Authorization header uses {{apiKey}}."
          }
        }
      ]
    },
    {
      "name": "Metering (direct)",
      "item": [
        {
          "name": "Metering Prometheus metrics",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": "http://localhost:8081/metrics"
          }
        }
      ]
    }
  ]
}
